# ── GitLab connection ──────────────────────────────────────────────────────────
# Personal Access Token (needs 'api' scope)
GITLAB_TOKEN=your_gitlab_personal_access_token_here

# GitLab instance URL (default: https://gitlab.com)
# For on-premises: http://10.20.8.14:30000
GITLAB_URL=https://gitlab.com

# Project path (without .git suffix)
GITLAB_PROJECT=cheerstech/report/network-line-settings

# Branch to read/write
GITLAB_BRANCH=master

# ── App ────────────────────────────────────────────────────────────────────────
# Port exposed on the host (default: 8080)
APP_PORT=8080
